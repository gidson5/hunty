# This is an example environment configuration file
# Copy this file to .env.local and update with your values for local development

# Environment type: development, staging, or production
NEXT_PUBLIC_ENVIRONMENT=development

# Base URL for the application
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Soroban network configuration
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_SOROBAN_NETWORK_TYPE=testnet

# API endpoints
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql

# Database connection
DATABASE_URL=postgresql://user:password@localhost:5432/hunty_dev

# IPFS Configuration (Pinata)
PINATA_JWT=your_pinata_jwt_token_here

# Email Service (Resend)
RESEND_API_KEY=your_resend_api_key_here

# Error Tracking (Sentry)
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# Security
CSP_REPORT_ONLY=true

# Deep Linking: Apple Universal Links
# Your 10-character Apple Team ID (find at developer.apple.com)
APPLE_TEAM_ID=
# iOS bundle ID — must match the production App Store bundle ID
IOS_BUNDLE_ID=com.yourorg.hunty

# Deep Linking: Android App Links
# Comma-separated SHA-256 certificate fingerprints (from your keystore)
ANDROID_SHA256_CERT_FINGERPRINTS=
# Android package name — must match the Play Store package name
ANDROID_PACKAGE_NAME=com.yourorg.hunty

# Feature Flags
NEXT_PUBLIC_ENABLE_STAGING_BANNER=false
