{
  "version": 2,
  "env": {
    "NEXT_PUBLIC_ENVIRONMENT": {
      "type": "select",
      "description": "Environment for deployment",
      "options": ["development", "staging", "production"]
    }
  },
  "buildCommand": "next build",
  "devCommand": "next dev --port $PORT",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": true,
      "staging": true
    }
  },
  "env": [
    {
      "key": "NEXT_PUBLIC_ENVIRONMENT",
      "scope": [
        "production",
        "preview",
        "development"
      ]
    },
    {
      "key": "NEXT_PUBLIC_SOROBAN_RPC_URL",
      "scope": [
        "production",
        "preview",
        "development"
      ]
    },
    {
      "key": "NEXT_PUBLIC_SOROBAN_NETWORK_PASSPHRASE",
      "scope": [
        "production",
        "preview",
        "development"
      ]
    },
    {
      "key": "NEXT_PUBLIC_SOROBAN_NETWORK_TYPE",
      "scope": [
        "production",
        "preview",
        "development"
      ]
    },
    {
      "key": "NEXT_PUBLIC_API_URL",
      "scope": [
        "production",
        "preview",
        "development"
      ]
    },
    {
      "key": "NEXT_PUBLIC_GRAPHQL_URL",
      "scope": [
        "production",
        "preview",
        "development"
      ]
    },
    {
      "key": "DATABASE_URL",
      "scope": [
        "production",
        "preview",
        "development"
      ]
    },
    {
      "key": "PINATA_JWT",
      "scope": [
        "production",
        "preview",
        "development"
      ]
    },
    {
      "key": "RESEND_API_KEY",
      "scope": [
        "production",
        "preview",
        "development"
      ]
    },
    {
      "key": "CSP_REPORT_ONLY",
      "scope": [
        "production",
        "preview",
        "development"
      ]
    }
  ],
  "regions": ["iad1"],
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/api/$1",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "HEAD", "OPTIONS"]
    }
  ]
}
