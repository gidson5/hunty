# Preview Environment Configuration
# Copy this file to .env.preview and fill in the values
# Used for QA and internal testing

# ============================================================================
# REQUIRED: App Environment
# ============================================================================
APP_ENV=preview

# ============================================================================
# REQUIRED: Expo & EAS Configuration
# ============================================================================
EAS_PROJECT_ID=your-eas-project-id
EXPO_TOKEN=your-expo-token
EXPO_UPDATE_URL=https://u.expo.dev/your-eas-project-id

# ============================================================================
# API Configuration
# ============================================================================
# Staging API server
EXPO_PUBLIC_API_BASE_URL=https://staging-api.hunty.app

# GraphQL Indexer (staging/testnet)
EXPO_PUBLIC_GRAPHQL_URL=https://indexer-staging.hunty.app/graphql

# ============================================================================
# Blockchain Configuration (Stellar Testnet)
# ============================================================================
EXPO_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
EXPO_PUBLIC_STELLAR_NETWORK=testnet

# ============================================================================
# Third-party Services
# ============================================================================
# WalletConnect
WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Sentry - Optional for preview
EXPO_PUBLIC_SENTRY_DSN=

# ============================================================================
# Apple Developer Account (required for iOS preview builds)
# ============================================================================
EXPO_APPLE_ID=${EXPO_APPLE_ID}
EXPO_ASC_APP_ID=${EXPO_ASC_APP_ID}
EXPO_APPLE_TEAM_ID=${EXPO_APPLE_TEAM_ID}

# ============================================================================
# Build Configuration
# ============================================================================
DEVELOPMENT_CLIENT_ENABLED=false
DEBUG_MODE=true
