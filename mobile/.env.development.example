# Development Environment Configuration
# Copy this file to .env.development and fill in the values
# Source: https://docs.expo.dev/eas/environment-variables/

# ============================================================================
# REQUIRED: App Environment
# ============================================================================
APP_ENV=development

# ============================================================================
# REQUIRED: Expo & EAS Configuration
# ============================================================================
# Get these from Expo Dashboard (https://expo.dev/projects)
EAS_PROJECT_ID=your-eas-project-id
EXPO_TOKEN=your-expo-token
EXPO_UPDATE_URL=https://u.expo.dev/your-eas-project-id

# ============================================================================
# API Configuration
# ============================================================================
# Local development server (run: npm run dev from root)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api

# GraphQL Indexer (local)
EXPO_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql

# ============================================================================
# Blockchain Configuration (Stellar Testnet)
# ============================================================================
EXPO_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
EXPO_PUBLIC_STELLAR_NETWORK=testnet

# ============================================================================
# Third-party Services
# ============================================================================
# WalletConnect - Register at https://cloud.reown.com
WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Sentry (Crash/Error Reporting) - Optional for development
EXPO_PUBLIC_SENTRY_DSN=

# ============================================================================
# Apple Developer Account (optional for local development)
# ============================================================================
# EXPO_APPLE_ID=your-apple-id
# EXPO_ASC_APP_ID=your-app-store-connect-id
# EXPO_APPLE_TEAM_ID=your-apple-team-id

# ============================================================================
# Build Configuration
# ============================================================================
DEVELOPMENT_CLIENT_ENABLED=true
DEBUG_MODE=true
