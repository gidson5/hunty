# Production Environment Configuration
# Copy this file to .env.production and fill in the values
# Used for App Store and Play Store releases

# ============================================================================
# REQUIRED: App Environment
# ============================================================================
APP_ENV=production

# ============================================================================
# REQUIRED: Expo & EAS Configuration
# ============================================================================
EAS_PROJECT_ID=your-eas-project-id
EXPO_TOKEN=your-expo-token
EXPO_UPDATE_URL=https://u.expo.dev/your-eas-project-id

# ============================================================================
# API Configuration
# ============================================================================
# Production API server
EXPO_PUBLIC_API_BASE_URL=https://api.hunty.app

# GraphQL Indexer (production/mainnet)
EXPO_PUBLIC_GRAPHQL_URL=https://indexer.hunty.app/graphql

# ============================================================================
# Blockchain Configuration (Stellar Mainnet)
# ============================================================================
EXPO_PUBLIC_STELLAR_RPC_URL=https://soroban-mainnet.stellar.org
EXPO_PUBLIC_STELLAR_NETWORK=mainnet

# ============================================================================
# Third-party Services
# ============================================================================
# WalletConnect
WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Sentry - Crash/Error Reporting for production
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================================
# Apple Developer Account (required for iOS production builds)
# ============================================================================
EXPO_APPLE_ID=${EXPO_APPLE_ID}
EXPO_ASC_APP_ID=${EXPO_ASC_APP_ID}
EXPO_APPLE_TEAM_ID=${EXPO_APPLE_TEAM_ID}

# ============================================================================
# Build Configuration
# ============================================================================
DEVELOPMENT_CLIENT_ENABLED=false
DEBUG_MODE=false
